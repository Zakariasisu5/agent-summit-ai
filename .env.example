# --- 0G Network (public, browser-safe) ---
NEXT_PUBLIC_0G_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_CHAIN_ID=16602
# Get your WalletConnect Project ID: https://cloud.reown.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here
NEXT_PUBLIC_0G_STORAGE_URL=https://indexer-storage-testnet-turbo.0g.ai
NEXT_PUBLIC_0G_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# Deployed contract addresses on 0G Galileo testnet (chainId 16602)
NEXT_PUBLIC_CONTRACT_IDENTITY=0xfF0c704F720D631dB7Cc70645fb9b596C2a093e7
NEXT_PUBLIC_CONTRACT_REPUTATION=0x6AF03aAc6CB8339AE1486c7B6D2Dd72e8FB3a397
NEXT_PUBLIC_CONTRACT_CREDENTIAL=0x1Bda18E14bDB064261044412e324be513A8A3f41

# --- Server-only secrets (NEVER prefix with NEXT_PUBLIC_) ---
# Funded 0G testnet signer for paid Storage uploads.
# Generate keys: node scripts/generate-keys.js
# Fund from faucet: https://faucet.0g.ai/
ZG_STORAGE_PRIVATE_KEY=your_storage_private_key_here

# NOTE: AI Analysis now uses USER-PAYS model.
# The connected wallet pays for AI inference using their own 0G tokens.
# Users must register their wallet with the 0G Serving Broker:
#   1. Fund wallet with at least 2 A0GI from https://faucet.0g.ai/
#   2. Register: 0g-compute-cli add-account --amount 2 --private-key YOUR_PRIVATE_KEY
#
# The ZG_COMPUTE_PRIVATE_KEY below is only used for legacy server-side functions.
ZG_COMPUTE_PRIVATE_KEY=your_compute_private_key_here

# Optional override for the inference endpoint surfaced by the Compute broker.
AI_API_URL=
